<t t-name="sale.report_saleorder_document">
    <t t-call="web.external_layout">
        <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)"/>
        <t t-set="forced_vat" t-value="doc.fiscal_position_id.foreign_vat"/>
        <t t-set="address">
        </t>
            <t t-if="doc.partner_shipping_id == doc.partner_invoice_id                              and doc.partner_invoice_id != doc.partner_id                              or doc.partner_shipping_id != doc.partner_invoice_id">
            <t t-set="information_block">
                </t>
            </t>
        <div class="page">
            <div class="oe_structure"/>

            <t t-set="is_proforma" t-value="env.context.get('proforma', False) or is_pro_forma"/>
            <t t-set="layout_document_title">
                <span t-if="is_proforma">Número de factura proforma </span>
                <span t-elif="doc.state in ['draft','sent']">Número de cotización </span>
                <span t-else="">Número de orden </span>
                <span t-field="doc.name">SO0000</span>
            </t>

            <div style="border: 1px solid #2c3e50; padding: 15px; margin-bottom: 15px;">
                    
                    <div class="row mb-3" style="margin-bottom: 6px !important;">
                        <div class="col" name="partner_name">
                            <strong>Cliente:</strong>
                            <t t-if="doc.is_final_consumer">
                                <div t-field="doc.end_customer_name"/>
                            </t>
                            <t t-else="">
                                <div t-field="doc.partner_id.name"/>
                            </t>
                        </div>
                        <div class="col" name="partner_vat">
                            <strong>Identificación:</strong>
                            <div t-field="doc.partner_id.vat"/>
                        </div>
                        <div class="col" name="partner_phone">
                            <strong>Teléfono:</strong>
                            <t t-if="doc.is_final_consumer">
                                <div t-field="doc.end_customer_phone"/>
                            </t>
                            <t t-else="">
                                <div t-field="doc.partner_id.phone"/>
                            </t>
                        </div>
                    </div>

                    <div class="row mb-3" style="margin-bottom: 6px !important;">
                        <div class="col" name="partner_address">
                            <strong>Dirección:</strong>
                                <div t-field="doc.partner_id" t-options="{&quot;widget&quot;: &quot;contact&quot;, &quot;fields&quot;: [&quot;street&quot;, &quot;city&quot;, &quot;state_id&quot;, &quot;country_id&quot;], &quot;no_marker&quot;: True}"/>
                        </div>
                        <div class="col" name="partner_email">
                            <strong>E-MAIL:</strong>
                            <t t-if="doc.is_final_consumer">
                                <div t-field="doc.end_customer_email"/>
                            </t>
                            <t t-else="">
                                <div t-field="doc.partner_id.email"/>
                            </t>
                        </div>
                    </div>

                    <div id="informations" class="row mb-3" style="margin-bottom: 6px !important;" t-if="doc.date_order or doc.client_order_ref or doc.validity_date or doc.user_id.name">
                        <div class="col" t-if="doc.name" name="document_number">
                            <strong>
                                <t t-if="is_proforma">Factura Pro-Forma #:</t>
                                <t t-elif="doc.state in ['draft','sent']">Cotización #:</t>
                                <t t-else="">Pedido #:</t>
                            </strong>
                            <div t-field="doc.name"/>
                        </div>
                        <div class="col" t-if="doc.date_order" name="date_order">
                            <strong>Fecha:</strong>
                            <div t-field="doc.date_order" t-options="{&quot;widget&quot;: &quot;date&quot;}"/>
                        </div>
                        <div class="col" t-if="doc.validity_date and doc.state in ['draft', 'sent']" name="validity_date">
                            <strong>Vencimiento:</strong>
                            <div t-field="doc.validity_date"/>
                        </div>
                        <div class="col" t-if="doc.user_id.name" name="salesperson">
                            <strong>Vendedor:</strong>
                            <div t-field="doc.user_id"/>
                        </div>
                    </div>

                </div>
            <t t-set="lines_to_report" t-value="doc._get_order_lines_to_report()"/>
            <t t-set="display_discount" t-value="any(l.discount for l in lines_to_report)"/>
            <t t-set="hide_taxes_details" t-value="False"/>
            <t t-set="display_taxes" t-value="not hide_taxes_details and any(l._has_taxes() for l in lines_to_report)"/>

            <table class="o_has_total_table table o_main_table table-borderless">
                <thead style="display: table-row-group">
                    <tr>
                        <th name="th_code" class="text-start">Código</th>
                        <th name="th_description" class="text-start">Descripción</th>
                        <th name="th_quantity" class="text-end text-nowrap">Cantidad</th>
                        <th name="th_priceunit" class="text-end text-nowrap">P. Unitario</th>
                        <th name="th_discount" t-if="display_discount" class="text-end">Descuento</th>
                        <th name="th_taxes" t-if="display_taxes" class="text-end">Impuestos</th>
                        <th name="th_subtotal" class="text-end">SubTotal</th>
                    </tr>
                </thead>
                <tbody class="sale_tbody">
                    <t t-set="current_section" t-value="None"/>
                    <t t-set="price_field" t-value="'price_total' if hide_taxes_details else 'price_subtotal'"/>

                    <t t-foreach="lines_to_report" t-as="line">
                        <t t-set="is_note" t-value="line.display_type == 'line_note'"/>
                        <t t-set="is_section" t-value="line.display_type == 'line_section'"/>

                        <tr t-if="not is_section and not is_note" name="tr_product">
                            <td name="td_code">
                                <span t-esc="line.product_id.barcode or line.product_id.default_code or ''"/>
                            </td>
                            <td name="td_product_name">
                                <span t-field="line.product_id.name"/>
                            </td>
                            <td name="td_product_quantity" class="text-end">
                                <span t-field="line.product_uom_qty"/>
                            </td>
                            <td name="td_product_priceunit" class="text-end">
                                <span t-field="line.price_unit" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </td>
                            <td t-if="display_discount" name="td_product_discount" class="text-end">
                                <span t-field="line.discount"/>%
                            </td>
                            <td t-if="display_taxes" name="td_product_taxes" class="text-end">
                                <span t-out="line.tax_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </td>
                            <td name="td_product_subtotal" class="text-end">
                                <span t-field="line.price_subtotal"/>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <div class="clearfix text-end" name="so_total_summary">
                <div class="row">
                    <div class="col-6 ms-auto">
                        <table class="table table-borderless">
                            <tr>
                                <td><strong>Subtotal</strong></td>
                                <td class="text-end"><span t-field="doc.amount_untaxed"/></td>
                            </tr>
                            <tr>
                                <td><strong>IVA</strong></td>
                                <td class="text-end"><span t-field="doc.amount_tax"/></td>
                            </tr>
                            <tr class="fw-bold">
                                <td><strong>Total</strong></td>
                                <td class="text-end"><span t-field="doc.amount_total"/></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>

            <div t-if="doc.payment_term_id">
                <p><strong>Términos de pago:</strong> <span t-field="doc.payment_term_id.name"/></p>
            </div>
        </div>
    </t>
</t>
